generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") 
}

enum UserRole {
  EGRESADO
  EMPLEADOR
  ADMIN
}

enum JobStatus {
  PENDING
  APPROVED
  REJECTED
  SPAM
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  role      UserRole
  carrera   String?
  telefono  String?
  created_at DateTime @default(now())
  jobs      Job[]    @relation("JobCreatedBy")
}

model Company {
  id         String @id @default(uuid())
  ruc        String @unique
  name       String
  rubro      String
  es_baneada Boolean @default(false)
  jobs       Job[]
}

model Job {
  id             String    @id @default(uuid())
  title          String
  description    String?
  company_id     String
  company_name   String?
  carrera_destino String
  salario_min    Int
  salario_max    Int
  requisitos     String
  status         JobStatus @default(PENDING)
  creado_en      DateTime  @default(now())
  company        Company   @relation(fields: [company_id], references: [id])
  created_by_id  String?
  created_by     User?     @relation("JobCreatedBy", fields: [created_by_id], references: [id])
}
