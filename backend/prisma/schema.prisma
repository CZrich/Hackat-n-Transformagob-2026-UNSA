generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  EGRESADO
  EMPLEADOR
  ADMIN
}

enum JobStatus {
  PENDING
  APPROVED
  REJECTED
  SPAM
}

enum ApplicationStatus {
  PENDING
  REVIEWED
  ACCEPTED
  REJECTED
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  name       String
  role       UserRole
  carrera    String?
  telefono   String?
  skills     String[]
  password   String?
  cv_name    String?
  cv_url     String?
  bio        String?
  created_at   DateTime      @default(now())
  company      Company?
  jobs         Job[]         @relation("JobCreatedBy")
  applications Application[]
}

model Company {
  id            String   @id @default(uuid())
  ruc           String   @unique
  name          String
  rubro         String
  direccion     String
  horario       String?
  es_verificada Boolean  @default(false)
  es_baneada    Boolean  @default(false)
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id])
  jobs          Job[]
}

model Job {
  id              String    @id @default(uuid())
  title           String
  description     String?
  company_id      String
  company_name    String?
  carrera_destino String
  salario_min     Int
  salario_max     Int
  fecha_inicio    DateTime
  fecha_fin       DateTime
  lugar           String
  horario         String
  perfil          String
  cantidad_req    Int
  requisitos      String
  funciones       String
  competencias    String[]
  status          JobStatus @default(APPROVED)
  creado_en       DateTime  @default(now())
  company         Company   @relation(fields: [company_id], references: [id])
  created_by_id   String?
  created_by      User?         @relation("JobCreatedBy", fields: [created_by_id], references: [id])
  applications    Application[]
}

model Application {
  id         String            @id @default(uuid())
  jobId      String
  userId     String
  status     ApplicationStatus @default(PENDING)
  created_at DateTime          @default(now())

  job  Job  @relation(fields: [jobId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([jobId, userId])
}
