generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  EGRESADO
  EMPLEADOR
  ADMIN
}

enum JobStatus {
  PENDING
  APPROVED
  REJECTED
  SPAM
  CLOSED
}

enum ApplicationStatus {
  PENDING
  REVIEWED
  ACCEPTED
  REJECTED
  CV_REVIEWED
  IN_PROCESS
  FINALIST
  PROCESS_FINISHED
}

model User {
  id           String            @id @default(uuid())
  email        String            @unique
  name         String
  role         UserRole
  password     String?
  created_at   DateTime          @default(now())
  company      Company?
  jobs         Job[]             @relation("JobCreatedBy")
  applications Application[]
  profile      GraduateProfile?
  ratings_given CompanyRating[]
}

model Company {
  id              String          @id @default(uuid())
  ruc             String          @unique
  name            String
  rubro           String
  direccion       String
  horario         String?
  contacto_telefono String?
  contacto_email  String?
  es_verificada   Boolean         @default(false)
  es_baneada      Boolean         @default(false)
  userId          String          @unique
  user            User            @relation(fields: [userId], references: [id])
  jobs            Job[]
  ratings         CompanyRating[]
  rating_promedio Float           @default(0)
  total_votos     Int             @default(0)
}

model CompanyRating {
  id        String   @id @default(uuid())
  companyId String
  userId    String
  score     Int
  comment   String?
  created_at DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([companyId, userId])
}

model GraduateProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  carrera         String?
  telefono        String?
  skills          String[]
  cv_name         String?
  cv_url          String?
  bio             String?
  summary         String?
  education       String?
  experience      String?
  certifications  String?
  languages       String?
  linkedin_url    String?
  portfolio_url   String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
}

model Job {
  id              String    @id @default(uuid())
  title           String
  description     String?
  company_id      String
  company_name    String?
  carrera_destino String
  salario_min     Int
  salario_max     Int
  fecha_inicio    DateTime
  fecha_fin       DateTime
  lugar           String
  horario         String
  perfil          String
  cantidad_req    Int
  requisitos      String
  funciones       String
  competencias    String[]
  status          JobStatus @default(APPROVED)
  creado_en       DateTime  @default(now())
  company         Company   @relation(fields: [company_id], references: [id])
  created_by_id   String?
  created_by      User?         @relation("JobCreatedBy", fields: [created_by_id], references: [id])
  applications    Application[]
}

model Application {
  id         String            @id @default(uuid())
  jobId      String
  userId     String
  status     ApplicationStatus @default(PENDING)
  created_at DateTime          @default(now())

  job  Job  @relation(fields: [jobId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([jobId, userId])
}
